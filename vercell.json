{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/shop.html", "destination": "/shop", "permanent": true },
    { "source": "/om.html", "destination": "/om", "permanent": true },
    { "source": "/forhandlere.html", "destination": "/forhandlere", "permanent": true },
    { "source": "/product.html", "destination": "/product", "permanent": true },
    { "source": "/checkout.html", "destination": "/checkout", "permanent": true },
    { "source": "/success.html", "destination": "/success", "permanent": true }
  ],
  "rewrites": [
    { "source": "/product", "destination": "/product.html" },
    { "source": "/shop", "destination": "/shop.html" },
    { "source": "/om", "destination": "/om.html" },
    { "source": "/forhandlere", "destination": "/forhandlere.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/success", "destination": "/success.html" }
  ]
}
